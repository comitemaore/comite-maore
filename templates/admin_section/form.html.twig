{# templates/admin_section/form.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}{{ mode == 'ajouter' ? 'Ajouter' : 'Modifier' }} un admin — Comité Maoré{% endblock %}
{% block body_theme %}dark{% endblock %}

{% block navbar %}
<nav class="navbar">
    <a class="navbar-brand" href="{{ path('app_dashboard') }}"> Comité Maoré</a>
    <div class="navbar-right">
        <a href="{{ path('app_admin_section_list') }}" class="btn btn-secondary btn-sm">← Retour</a>
        <a href="{{ path('app_logout') }}" class="btn btn-danger btn-sm">Déconnexion</a>
    </div>
</nav>
{% endblock %}

{% block body %}
<div class="layout">
    <aside class="sidebar">
        <a href="{{ path('app_dashboard') }}">📊 Tableau de bord</a>
        <a href="{{ path('app_adherent_list') }}">👥 Adhérents</a>
        <a href="{{ path('app_admin_section_list') }}" class="active">🔑 Admins sections</a>
        <a href="{{ path('app_log_list') }}">📋 Logs</a>
        <hr style="margin:16px 20px;border:none;border-top:1px solid rgba(255,255,255,.15);">
        <a href="{{ path('app_logout') }}">🚪 Déconnexion</a>
    </aside>

    <main class="main-content">
        <h1 style="font-size:22px;font-weight:700;margin-bottom:4px;">
            🔑 {{ mode == 'ajouter' ? 'Ajouter un administrateur' : 'Modifier un administrateur' }}
        </h1>
        <p style="font-size:13px;opacity:.5;margin-bottom:24px;">
            Le login doit correspondre exactement au login défini dans <code>security.yaml</code>.
        </p>

        {% if error %}<div class="alert alert-danger">{{ error }}</div>{% endif %}

        <div class="card" style="max-width:560px;">
            <form method="post">
                <div class="form-group">
                    <label>Section *</label>
                    <select name="id_section" class="form-control" required>
                        <option value="">-- Choisir une section --</option>
                        {% for s in sections %}
                            <option value="{{ s.id_section }}"
                                {{ (admin.id_section ?? '') == s.id_section ? 'selected' : '' }}>
                                {{ s.section }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group">
                    <label>Login Symfony *
                        <span style="font-size:11px;opacity:.5;">(doit correspondre à security.yaml)</span>
                    </label>
                    <input type="text" name="login_admin" class="form-control" required
                           placeholder="ex: admin, root, user1..."
                           value="{{ admin.login_admin ?? '' }}">
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                    <div class="form-group">
                        <label>Prénom *</label>
                        <input type="text" name="prenom_admin" class="form-control" required
                               value="{{ admin.prenom_admin ?? '' }}">
                    </div>
                    <div class="form-group">
                        <label>Nom *</label>
                        <input type="text" name="nom_admin" class="form-control" required
                               value="{{ admin.nom_admin ?? '' }}">
                    </div>
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email_admin" class="form-control"
                           placeholder="admin@comite-maore.org"
                           value="{{ admin.email_admin ?? '' }}">
                </div>

                <div class="form-group">
                    <label>Rang dans la section *
                        <span style="font-size:11px;opacity:.5;">(1, 2 ou 3 — unique par section)</span>
                    </label>
                    <select name="rang" class="form-control" required>
                        {% for r in 1..3 %}
                            <option value="{{ r }}" {{ (admin.rang ?? 1) == r ? 'selected' : '' }}>
                                Rang {{ r }}{% if r == 1 %} — Initiateur principal{% endif %}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                {% if mode == 'modifier' %}
                <div class="form-group">
                    <label>Statut</label>
                    <select name="actif" class="form-control">
                        <option value="1" {{ (admin.actif ?? 1) == 1 ? 'selected' : '' }}>Actif</option>
                        <option value="0" {{ (admin.actif ?? 1) == 0 ? 'selected' : '' }}>Inactif</option>
                    </select>
                </div>
                {% endif %}

                <div style="display:flex;gap:10px;margin-top:8px;">
                    <button type="submit" class="btn btn-success">
                        {{ mode == 'ajouter' ? '+ Ajouter' : '💾 Enregistrer' }}
                    </button>
                    <a href="{{ path('app_admin_section_list') }}" class="btn btn-secondary">Annuler</a>
                </div>
            </form>
        </div>

        <div class="card" style="max-width:560px;margin-top:16px;">
            <div class="card-title" style="font-size:14px;">Logins disponibles dans security.yaml</div>
            <div style="font-size:13px;opacity:.6;line-height:1.8;">
                Vérifiez vos logins avec :<br>
                <code style="font-size:12px;background:rgba(255,255,255,.08);padding:2px 8px;border-radius:4px;">
                    grep -A2 "users:" config/packages/security.yaml
                </code>
            </div>
        </div>
    </main>
</div>
<style>
    code{font-family:'Courier New',monospace;}
    .btn-primary{background:#4299e1;color:#fff;}
</style>
{% endblock %}
