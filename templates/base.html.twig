{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Base de données Comité Maore{% endblock %}</title>
    <style>
        /* ===== RESET & BASE ===== */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; min-height: 100vh; }

        /* ===== THÈME DARK (admin) ===== */
        body.theme-dark {
            background: #0f1117;
            color: #e2e8f0;
        }
        body.theme-dark .navbar  { background: #1a1d26; border-bottom: 1px solid #2d3748; }
        body.theme-dark .card    { background: #1e2330; border: 1px solid #2d3748; }
        body.theme-dark .form-control { background: #2d3748; color: #e2e8f0; border: 1px solid #4a5568; }
        body.theme-dark .btn-primary  { background: #4299e1; color: #fff; }
        body.theme-dark .btn-primary:hover { background: #3182ce; }
        body.theme-dark .table thead   { background: #2d3748; }
        body.theme-dark .table tbody tr:nth-child(even) { background: #1a202c; }
        body.theme-dark .table tbody tr:nth-child(odd)  { background: #1e2330; }
        body.theme-dark .sidebar { background: #1a1d26; border-right: 1px solid #2d3748; }
        body.theme-dark .sidebar a { color: #a0aec0; }
        body.theme-dark .sidebar a:hover, body.theme-dark .sidebar a.active { background: #2d3748; color: #63b3ed; }
        body.theme-dark .badge-admin { background: #e53e3e; color: #fff; }

        /* ===== THÈME SKY (user1 / bleu ciel) ===== */
        body.theme-sky {
            background: #e8f4fd;
            color: #1a365d;
        }
        body.theme-sky .navbar  { background: #2b6cb0; color: white; }
        body.theme-sky .navbar a { color: #bee3f8; }
        body.theme-sky .card    { background: #ffffff; border: 1px solid #bee3f8; box-shadow: 0 2px 8px rgba(66,153,225,.12); }
        body.theme-sky .form-control { background: #fff; color: #1a365d; border: 1px solid #90cdf4; }
        body.theme-sky .btn-primary  { background: #3182ce; color: #fff; }
        body.theme-sky .btn-primary:hover { background: #2c5282; }
        body.theme-sky .table thead   { background: #2b6cb0; color: white; }
        body.theme-sky .table tbody tr:nth-child(even) { background: #ebf8ff; }
        body.theme-sky .table tbody tr:nth-child(odd)  { background: #ffffff; }
        body.theme-sky .sidebar { background: #2b6cb0; }
        body.theme-sky .sidebar a { color: #bee3f8; }
        body.theme-sky .sidebar a:hover, body.theme-sky .sidebar a.active { background: #2c5282; color: #fff; }
        body.theme-sky .badge-user { background: #38a169; color: #fff; }

        /* ===== THÈME DEFAULT (page accueil, fond vert) ===== */
        body.theme-default {
            background: #1a4731;
        }

        /* ===== COMPOSANTS COMMUNS ===== */
        .navbar {
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 24px; height: 56px;
        }
        .navbar-brand { font-size: 16px; font-weight: 600; color: inherit; text-decoration: none; }
        .navbar-right  { display: flex; align-items: center; gap: 12px; }
        .btn {
            display: inline-block; padding: 8px 18px; border-radius: 6px;
            border: none; cursor: pointer; font-size: 14px; font-weight: 500;
            text-decoration: none; transition: background .2s;
        }
        .btn-sm { padding: 5px 12px; font-size: 13px; }
        .btn-danger  { background: #e53e3e; color: #fff; }
        .btn-danger:hover { background: #c53030; }
        .btn-success { background: #38a169; color: #fff; }
        .btn-success:hover { background: #2f855a; }
        .btn-secondary { background: #718096; color: #fff; }
        .badge { display: inline-block; padding: 3px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; }
        .layout { display: flex; min-height: calc(100vh - 56px); }
        .sidebar {
            width: 220px; flex-shrink: 0; padding: 20px 0;
        }
        .sidebar a {
            display: flex; align-items: center; gap: 8px;
            padding: 10px 20px; text-decoration: none; font-size: 14px;
            border-radius: 0; transition: background .15s;
        }
        .main-content { flex: 1; padding: 32px; overflow-x: auto; }
        .card { border-radius: 10px; padding: 24px; margin-bottom: 20px; }
        .card-title { font-size: 18px; font-weight: 600; margin-bottom: 16px; }
        .form-group { margin-bottom: 16px; }
        label { display: block; font-size: 13px; font-weight: 500; margin-bottom: 5px; }
        .form-control {
            width: 100%; padding: 9px 12px; border-radius: 6px;
            font-size: 14px; outline: none; transition: border-color .2s;
        }
        .form-control:focus { border-color: #4299e1; }
        textarea.form-control { font-family: 'Courier New', monospace; font-size: 13px; resize: vertical; }
        .table { width: 100%; border-collapse: collapse; font-size: 13px; }
        .table th, .table td { padding: 9px 14px; text-align: left; border-bottom: 1px solid rgba(0,0,0,.08); }
        .table th { font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: .04em; }
        .alert { padding: 12px 16px; border-radius: 6px; margin-bottom: 16px; font-size: 14px; }
        .alert-danger  { background: #fff5f5; color: #c53030; border: 1px solid #feb2b2; }
        .alert-success { background: #f0fff4; color: #276749; border: 1px solid #9ae6b4; }
        body.theme-dark .alert-danger  { background: #2d0000; color: #fc8181; border-color: #e53e3e; }
        body.theme-dark .alert-success { background: #00200a; color: #68d391; border-color: #38a169; }
        .empty-state { text-align: center; padding: 40px; opacity: .5; font-size: 14px; }
        select.form-control { appearance: auto; }
    </style>
</head>
<body class="theme-{% block body_theme %}default{% endblock %}">

{% block navbar %}{% endblock %}

{% block body %}{% endblock %}

</body>
</html>