{# templates/finance/section.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}Finances — Section {{ section.section }}{% endblock %}
{% block body_theme %}{{ is_admin ? 'dark' : 'sky' }}{% endblock %}

{% block navbar %}
<nav class="navbar">
    <a class="navbar-brand" href="{{ path('app_dashboard') }}"> Comité Maoré</a>
    <div class="navbar-right">
        <a href="{{ path('app_finance_ben') }}" class="btn btn-secondary btn-sm">📊 BEN</a>
        <a href="{{ path('app_logout') }}" class="btn btn-danger btn-sm">Déconnexion</a>
    </div>
</nav>
{% endblock %}

{% block body %}
<div class="layout">
    <aside class="sidebar">
        <a href="{{ path('app_dashboard') }}">📊 Tableau de bord</a>
        <a href="{{ path('app_adherent_list') }}">👥 Adhérents</a>
        <a href="{{ path('app_finance_ben') }}" class="active">💰 Finances BEN</a>
        {% if is_admin %}<a href="{{ path('app_log_list') }}">📋 Logs</a>{% endif %}
        <hr style="margin:16px 20px;border:none;border-top:1px solid rgba(255,255,255,.15);">
        <a href="{{ path('app_logout') }}">🚪 Déconnexion</a>
    </aside>

    <main class="main-content">

        {# En-tête #}
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;">
            <div>
                <h1 style="font-size:22px;font-weight:700;margin-bottom:4px;">
                    💰 Section {{ section.section }}
                </h1>
                <div style="font-size:13px;opacity:.6;">
                    Fédération : {{ section.nom_federation ?? '—' }} ·
                    id_section : {{ section.id_section }}
                </div>
            </div>
            {# Sélecteur année #}
            <form method="get" style="display:flex;align-items:center;gap:8px;">
                <label style="font-size:13px;opacity:.6;">Année :</label>
                <select name="annee" class="form-control" onchange="this.form.submit()"
                        style="width:100px;">
                    {% for a in annees %}
                        <option value="{{ a }}" {{ a == annee ? 'selected' : '' }}>{{ a }}</option>
                    {% endfor %}
                    <option value="0" {{ annee == 0 ? 'selected' : '' }}>Toutes</option>
                </select>
            </form>
        </div>

        {# Répartition 50/30/20 #}
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px;">

            <div class="card" style="border:1px solid rgba(239,159,39,.3);text-align:center;">
                <div style="font-size:11px;font-weight:600;opacity:.5;text-transform:uppercase;margin-bottom:6px;">
                    Part Bureau National (50%)
                </div>
                <div style="font-size:28px;font-weight:700;color:#fbd38d;">
                    {{ soldes.total_ben|number_format(2, ',', ' ') }} €
                </div>
            </div>

            <div class="card" style="border:1px solid rgba(99,179,237,.3);text-align:center;">
                <div style="font-size:11px;font-weight:600;opacity:.5;text-transform:uppercase;margin-bottom:6px;">
                    Part Fédération (30%)
                </div>
                <div style="font-size:28px;font-weight:700;color:#90cdf4;">
                    {{ soldes.total_fed|number_format(2, ',', ' ') }} €
                </div>
            </div>

            <div class="card" style="border:1px solid rgba(104,211,145,.3);text-align:center;">
                <div style="font-size:11px;font-weight:600;opacity:.5;text-transform:uppercase;margin-bottom:6px;">
                    Part Section (20%)
                </div>
                <div style="font-size:28px;font-weight:700;color:#9ae6b4;">
                    {{ soldes.total_section|number_format(2, ',', ' ') }} €
                </div>
            </div>
        </div>

        {# Détail des entrées #}
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;">
            {% for label, val, color in [
                ['Cotisations',  soldes.total_cotis,    '#e9d8fd'],
                ['Dons',         soldes.total_dons,     '#fed7d7'],
                ['Cotis. dues',  soldes.total_dues,     '#feebc8'],
                ['Ristournes',   soldes.total_ristourne,'#c6f6d5']
            ] %}
            <div class="card" style="text-align:center;padding:14px;">
                <div style="font-size:11px;opacity:.5;text-transform:uppercase;margin-bottom:4px;">{{ label }}</div>
                <div style="font-size:20px;font-weight:700;color:{{ color|default('#000') }};">
                    {{ val|number_format(2, ',', ' ') }} €
                </div>
            </div>
            {% endfor %}
        </div>

        {# Résumé par type d'opération #}
        <div class="card" style="margin-bottom:16px;">
            <div class="card-title">Résumé par type d'opération — {{ annee == 0 ? 'Toutes années' : annee }}</div>
            <table class="table">
                <thead>
                    <tr>
                        <th>Type</th><th>Nb opérations</th><th>Total</th>
                        <th>Part section (20%)</th>
                    </tr>
                </thead>
                <tbody>
                    {% for t in par_type %}
                    <tr>
                        <td>
                            <span style="padding:2px 8px;border-radius:4px;font-size:12px;
                                background:rgba(255,255,255,.08);">
                                {{ t.type_operation|replace({'_': ' '})|title }}
                            </span>
                        </td>
                        <td>{{ t.nb }}</td>
                        <td><strong>{{ t.total|number_format(2, ',', ' ') }} €</strong></td>
                        <td style="color:#9ae6b4;">{{ t.part_section|number_format(2, ',', ' ') }} €</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="4" style="opacity:.4;text-align:center;">Aucune opération</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# Historique des opérations #}
        <div class="card" style="padding:0;overflow:hidden;">
            <div style="padding:14px 16px;border-bottom:1px solid rgba(255,255,255,.08);">
                <span style="font-weight:600;">Historique des opérations</span>
                <span style="font-size:12px;opacity:.5;margin-left:8px;">
                    {{ operations|length }} opération(s)
                </span>
            </div>
            <div style="overflow-x:auto;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Date</th><th>NIN</th><th>Adhérent</th><th>Type</th>
                            <th>Montant</th><th>→ BEN</th><th>→ Féd.</th><th>→ Sec.</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for op in operations %}
                        <tr>
                            <td style="font-size:12px;white-space:nowrap;">
                                {{ op.date_operation|date('d/m/Y') }}
                            </td>
                            <td style="font-family:monospace;font-size:11px;">
                                {{ op.NIN_adh ?? '—' }}
                            </td>
                            <td style="font-size:13px;">
                                {{ op.nom_adht }} {{ op.prenom_adht }}
                            </td>
                            <td>
                                <span style="font-size:11px;padding:1px 6px;border-radius:3px;
                                    background:rgba(255,255,255,.07);">
                                    {{ op.type_operation|replace({'_': ' '})|title }}
                                </span>
                            </td>
                            <td><strong>{{ op.montant|number_format(2, ',', ' ') }} €</strong></td>
                            <td style="font-size:12px;color:#fbd38d;">
                                {{ op.montant_burnatexec|number_format(2, ',', ' ') }} €
                            </td>
                            <td style="font-size:12px;color:#90cdf4;">
                                {{ op.montant_fedcorresp|number_format(2, ',', ' ') }} €
                            </td>
                            <td style="font-size:12px;color:#9ae6b4;">
                                {{ op.montant_sectcorresp|number_format(2, ',', ' ') }} €
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="8" style="opacity:.4;text-align:center;padding:20px;">
                            Aucune opération pour {{ annee == 0 ? 'toutes les années' : annee }}
                        </td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

    </main>
</div>
{% endblock %}
