{# templates/finance/show.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}Finances — {{ adherent.prenom_adht }} {{ adherent.nom_adht }}{% endblock %}
{% block body_theme %}{{ is_admin ? 'dark' : 'sky' }}{% endblock %}

{% block navbar %}
<nav class="navbar">
    <a class="navbar-brand" href="{{ path('app_dashboard') }}"> Comité Maoré</a>
    <div class="navbar-right">
        <span style="font-size:13px;opacity:.8;">{{ app.user.userIdentifier }}</span>
        {% if is_admin %}<span class="badge badge-admin">ADMIN</span>
        {% else %}<span class="badge badge-user">USER</span>{% endif %}
        <a href="{{ path('app_logout') }}" class="btn btn-danger btn-sm">Déconnexion</a>
    </div>
</nav>
{% endblock %}

{% block body %}
<div class="layout">
    <aside class="sidebar">
        <a href="{{ path('app_dashboard') }}">📊 Tableau de bord</a>
        <a href="{{ path('app_adherent_list') }}">👥 Adhérents</a>
        <a href="{{ path('app_finance_ben') }}">💰 Finances BEN</a>
        {% if is_admin %}<a href="{{ path('app_log_list') }}">📋 Logs</a>{% endif %}
        <hr style="margin:16px 20px;border:none;border-top:1px solid rgba(255,255,255,.15);">
        <a href="{{ path('app_logout') }}">🚪 Déconnexion</a>
    </aside>

    <main class="main-content">

        {# En-tête adhérent #}
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;">
            <div>
                <div style="font-size:12px;opacity:.4;margin-bottom:4px;text-transform:uppercase;letter-spacing:.05em;">
                    État financier adhérent
                </div>
                <h1 style="font-size:22px;font-weight:700;margin-bottom:6px;">
                    💰 {{ adherent.prenom_adht }} {{ adherent.nom_adht }}
                </h1>
                <div style="display:flex;gap:8px;flex-wrap:wrap;font-size:12px;">
                    <span style="font-family:monospace;padding:2px 8px;border-radius:4px;
                                 background:rgba(255,255,255,.07);">
                        NIN : {{ adherent.NIN_adh ?? '—' }}
                    </span>
                    {% if adherent.nom_federation %}
                        <a href="{{ path('app_fiche_federation', {id: adherent.id_federation}) }}"
                           style="padding:2px 8px;border-radius:4px;background:rgba(99,179,237,.12);
                                  color:#90cdf4;text-decoration:none;">
                            🏘 {{ adherent.nom_federation }}
                        </a>
                    {% endif %}
                    {% if adherent.nom_section %}
                        <a href="{{ path('app_fiche_section', {id: adherent.id_section}) }}"
                           style="padding:2px 8px;border-radius:4px;background:rgba(104,211,145,.1);
                                  color:#9ae6b4;text-decoration:none;">
                            📍 {{ adherent.nom_section }}
                        </a>
                    {% endif %}
                    <span style="padding:2px 8px;border-radius:4px;
                        background:{{ adherent.cotis_adht == 'Oui' ? 'rgba(56,161,105,.15)' : 'rgba(229,62,62,.12)' }};
                        color:{{ adherent.cotis_adht == 'Oui' ? '#9ae6b4' : '#fc8181' }};">
                        {{ adherent.cotis_adht == 'Oui' ? '✓ Cotisant' : '✗ Non cotisant' }}
                    </span>
                </div>
            </div>
            <div style="display:flex;gap:8px;">
                <a href="{{ path('app_adherent_show', {id: adherent.id_adht}) }}"
                   class="btn btn-secondary btn-sm">👤 Fiche adhérent</a>
                <a href="{{ path('app_adherent_list') }}" class="btn btn-secondary btn-sm">← Liste</a>
            </div>
        </div>

        {# Alerte cotisations dues non réglées #}
        {% if dues_non_reglees|length > 0 %}
        <div style="padding:12px 16px;border-radius:8px;margin-bottom:16px;
                    background:rgba(229,62,62,.12);border:1px solid rgba(229,62,62,.3);
                    display:flex;align-items:center;gap:10px;">
            <span style="font-size:20px;">⚠️</span>
            <div>
                <div style="font-size:14px;font-weight:600;color:#fc8181;">
                    {{ dues_non_reglees|length }} cotisation(s) due(s) non réglée(s)
                </div>
                <div style="font-size:12px;opacity:.6;margin-top:2px;">
                    Années concernées :
                    {% for d in dues_non_reglees %}
                        <strong>{{ d.annee }}</strong>
                        ({{ d.statut == 'partiellement_payee' ? 'partiel — reste ' ~ d.solde_restant|number_format(2,',',' ') ~ ' €' : 'impayée — ' ~ d.montant_du|number_format(2,',',' ') ~ ' €' }})
                        {% if not loop.last %}, {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}

        {# KPIs globaux #}
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;">
            <div class="card" style="text-align:center;padding:16px;">
                <div style="font-size:11px;opacity:.4;text-transform:uppercase;margin-bottom:6px;">Total versé</div>
                <div style="font-size:26px;font-weight:700;color:#e2e8f0;">
                    {{ soldes.total|number_format(2, ',', ' ') }} €
                </div>
                <div style="font-size:11px;opacity:.4;margin-top:4px;">
                    {{ soldes.nb_operations }} opération(s)
                </div>
            </div>
            <div class="card" style="text-align:center;padding:16px;border:1px solid rgba(233,216,253,.2);">
                <div style="font-size:11px;opacity:.4;text-transform:uppercase;margin-bottom:6px;">Cotisations</div>
                <div style="font-size:26px;font-weight:700;color:#e9d8fd;">
                    {{ soldes.cotisations|number_format(2, ',', ' ') }} €
                </div>
            </div>
            <div class="card" style="text-align:center;padding:16px;border:1px solid rgba(254,215,170,.2);">
                <div style="font-size:11px;opacity:.4;text-transform:uppercase;margin-bottom:6px;">Dons</div>
                <div style="font-size:26px;font-weight:700;color:#fbd38d;">
                    {{ soldes.dons|number_format(2, ',', ' ') }} €
                </div>
            </div>
            <div class="card" style="text-align:center;padding:16px;border:1px solid rgba(198,246,213,.2);">
                <div style="font-size:11px;opacity:.4;text-transform:uppercase;margin-bottom:6px;">Ristournes</div>
                <div style="font-size:26px;font-weight:700;color:#c6f6d5;">
                    {{ soldes.ristournes|number_format(2, ',', ' ') }} €
                </div>
            </div>
        </div>

        {# Répartition 50/30/20 #}
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px;">
            <div class="card" style="border:1px solid rgba(239,159,39,.3);text-align:center;padding:14px;">
                <div style="font-size:11px;font-weight:600;opacity:.5;text-transform:uppercase;margin-bottom:6px;">
                    Contribution BEN (50%)
                </div>
                <div style="font-size:22px;font-weight:700;color:#fbd38d;">
                    {{ soldes.vers_ben|number_format(2, ',', ' ') }} €
                </div>
            </div>
            <div class="card" style="border:1px solid rgba(99,179,237,.3);text-align:center;padding:14px;">
                <div style="font-size:11px;font-weight:600;opacity:.5;text-transform:uppercase;margin-bottom:6px;">
                    Contribution fédération (30%)
                </div>
                <div style="font-size:22px;font-weight:700;color:#90cdf4;">
                    {{ soldes.vers_fed|number_format(2, ',', ' ') }} €
                </div>
            </div>
            <div class="card" style="border:1px solid rgba(104,211,145,.3);text-align:center;padding:14px;">
                <div style="font-size:11px;font-weight:600;opacity:.5;text-transform:uppercase;margin-bottom:6px;">
                    Contribution section (20%)
                </div>
                <div style="font-size:22px;font-weight:700;color:#9ae6b4;">
                    {{ soldes.vers_section|number_format(2, ',', ' ') }} €
                </div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

            {# Résumé par année #}
            <div class="card">
                <div class="card-title">📅 Résumé par année</div>
                {% if par_annee|length > 0 %}
                <table class="table">
                    <thead>
                        <tr>
                            <th>Année</th><th>Cotis.</th><th>Dons</th>
                            <th style="color:#fbd38d;">BEN</th><th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for a in par_annee %}
                        <tr>
                            <td><strong>{{ a.annee }}</strong></td>
                            <td>{{ a.cotisations|number_format(2, ',', ' ') }} €</td>
                            <td>{{ a.dons|number_format(2, ',', ' ') }} €</td>
                            <td style="color:#fbd38d;font-size:12px;">{{ a.vers_ben|number_format(2, ',', ' ') }} €</td>
                            <td><strong>{{ a.total|number_format(2, ',', ' ') }} €</strong></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                {% else %}
                    <p style="opacity:.3;text-align:center;padding:16px;font-style:italic;">
                        Aucune opération enregistrée.
                    </p>
                {% endif %}
            </div>

            {# Résumé par type + cotisations dues #}
            <div style="display:flex;flex-direction:column;gap:16px;">

                <div class="card">
                    <div class="card-title">📊 Par type d'opération</div>
                    <table class="table">
                        <thead>
                            <tr><th>Type</th><th>Nb</th><th>Total</th></tr>
                        </thead>
                        <tbody>
                            {% for t in par_type %}
                            <tr>
                                <td>
                                    <span style="font-size:11px;padding:1px 6px;border-radius:3px;
                                        background:rgba(255,255,255,.07);">
                                        {{ t.type_operation|replace({'_': ' '})|title }}
                                    </span>
                                </td>
                                <td style="font-size:12px;opacity:.6;">{{ t.nb }}</td>
                                <td><strong>{{ t.total|number_format(2, ',', ' ') }} €</strong></td>
                            </tr>
                            {% else %}
                            <tr><td colspan="3" style="opacity:.3;text-align:center;padding:12px;">—</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {# Cotisations dues #}
                <div class="card" style="border:1px solid rgba({{ dues_non_reglees|length > 0 ? '229,62,62' : '255,255,255' }},.2);">
                    <div class="card-title">
                        🗓 Cotisations dues
                        {% if dues_non_reglees|length > 0 %}
                            <span style="font-size:11px;padding:2px 8px;border-radius:10px;
                                         background:rgba(229,62,62,.2);color:#fc8181;margin-left:6px;">
                                {{ dues_non_reglees|length }} impayée(s)
                            </span>
                        {% endif %}
                    </div>
                    {% if cotisations_dues|length > 0 %}
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Année</th>
                                <th>Dû</th>
                                <th>Payé</th>
                                <th>Solde restant</th>
                                <th>Statut</th>
                                <th>Créé le</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for d in cotisations_dues %}
                            <tr style="{{ d.statut != 'soldee' ? 'background:rgba(229,62,62,.05);' : '' }}">
                                <td><strong>{{ d.annee }}</strong></td>
                                <td>{{ d.montant_du|number_format(2, ',', ' ') }} €</td>
                                <td style="color:#9ae6b4;">{{ d.montant_paye|number_format(2, ',', ' ') }} €</td>
                                <td style="font-weight:600;color:{{ d.solde_restant > 0 ? '#fc8181' : '#9ae6b4' }};">
                                    {{ d.solde_restant|number_format(2, ',', ' ') }} €
                                </td>
                                <td>
                                    {% if d.statut == 'soldee' %}
                                        <span class="badge" style="background:#276749;color:#9ae6b4;">✓ Soldée</span>
                                    {% elseif d.statut == 'partiellement_payee' %}
                                        <span class="badge" style="background:#744210;color:#fbd38d;">~ Partiel</span>
                                    {% else %}
                                        <span class="badge" style="background:#742a2a;color:#fc8181;">✗ Due</span>
                                    {% endif %}
                                </td>
                                <td style="font-size:11px;opacity:.5;">
                                    {{ d.date_creation ? d.date_creation|date('d/m/Y') : '—' }}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr style="font-weight:700;border-top:1px solid rgba(255,255,255,.15);">
                                <td>TOTAL</td>
                                <td>{{ cotisations_dues|map(d => d.montant_du)|reduce((carry, v) => carry + v, 0)|number_format(2, ',', ' ') }} €</td>
                                <td style="color:#9ae6b4;">{{ cotisations_dues|map(d => d.montant_paye)|reduce((carry, v) => carry + v, 0)|number_format(2, ',', ' ') }} €</td>
                                <td style="color:#fc8181;">{{ cotisations_dues|map(d => d.solde_restant)|reduce((carry, v) => carry + v, 0)|number_format(2, ',', ' ') }} €</td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                    {% else %}
                        <p style="opacity:.3;text-align:center;padding:12px;font-style:italic;font-size:13px;">
                            Aucune cotisation due enregistrée.
                        </p>
                    {% endif %}
                </div>

            </div>
        </div>

        {# Historique complet des opérations #}
        <div class="card" style="padding:0;overflow:hidden;">
            <div style="padding:14px 16px;border-bottom:1px solid rgba(255,255,255,.08);
                        display:flex;justify-content:space-between;align-items:center;">
                <span style="font-weight:600;">
                    Historique complet
                    <span style="font-size:12px;opacity:.5;margin-left:6px;">
                        {{ operations|length }} opération(s)
                        {% if soldes.premiere_operation %}
                            · depuis {{ soldes.premiere_operation|date('d/m/Y') }}
                        {% endif %}
                    </span>
                </span>
                {% if is_admin %}
                <a href="{{ path('app_finance_show', {idAdht: adherent.id_adht}) }}"
                   class="btn btn-success btn-sm">+ Opération</a>
                {% endif %}
            </div>
            {% if operations|length > 0 %}
            <div style="overflow-x:auto;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Date</th><th>Type</th><th>Montant</th>
                            <th style="color:#fbd38d;">→ BEN (50%)</th>
                            <th style="color:#90cdf4;">→ Féd. (30%)</th>
                            <th style="color:#9ae6b4;">→ Sec. (20%)</th>
                            <th>Année cotis.</th><th>Note</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for op in operations %}
                        <tr style="{{ op.type_operation == 'cotisation_due' and not op.cotis_due_payee
                            ? 'background:rgba(229,62,62,.06);' : '' }}">
                            <td style="font-size:12px;white-space:nowrap;">
                                {{ op.date_operation|date('d/m/Y') }}
                            </td>
                            <td>
                                <span style="font-size:11px;padding:2px 7px;border-radius:4px;
                                    background:{% if op.type_operation == 'cotisation' %}rgba(159,122,234,.15)
                                    {% elseif op.type_operation == 'don' %}rgba(246,173,85,.15)
                                    {% elseif op.type_operation == 'ristourne' %}rgba(104,211,145,.12)
                                    {% elseif op.type_operation == 'cotisation_due' %}rgba(229,62,62,.15)
                                    {% else %}rgba(255,255,255,.07){% endif %};">
                                    {{ op.type_operation|replace({'_': ' '})|title }}
                                </span>
                                {% if op.type_operation == 'cotisation_due' and not op.cotis_due_payee %}
                                    <span style="font-size:10px;color:#fc8181;margin-left:4px;">⚠ impayée</span>
                                {% endif %}
                                {% if op.type_operation == 'don' and op.nature_don %}
                                    <div style="font-size:10px;opacity:.5;margin-top:1px;">{{ op.nature_don }}</div>
                                {% endif %}
                            </td>
                            <td>
                                <strong>{{ op.montant|number_format(2, ',', ' ') }} €</strong>
                            </td>
                            <td style="font-size:12px;color:#fbd38d;">
                                {{ op.montant_burnatexec|number_format(2, ',', ' ') }} €
                            </td>
                            <td style="font-size:12px;color:#90cdf4;">
                                {{ op.montant_fedcorresp|number_format(2, ',', ' ') }} €
                            </td>
                            <td style="font-size:12px;color:#9ae6b4;">
                                {{ op.montant_sectcorresp|number_format(2, ',', ' ') }} €
                            </td>
                            <td style="font-size:12px;opacity:.5;">
                                {{ op.annee_cotisation ?? '—' }}
                            </td>
                            <td style="font-size:12px;opacity:.5;max-width:160px;">
                                {{ op.note ? op.note|slice(0,60) ~ (op.note|length > 60 ? '…' : '') : '—' }}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr style="font-weight:700;border-top:2px solid rgba(255,255,255,.15);">
                            <td colspan="2">TOTAL</td>
                            <td>{{ soldes.total|number_format(2, ',', ' ') }} €</td>
                            <td style="color:#fbd38d;">{{ soldes.vers_ben|number_format(2, ',', ' ') }} €</td>
                            <td style="color:#90cdf4;">{{ soldes.vers_fed|number_format(2, ',', ' ') }} €</td>
                            <td style="color:#9ae6b4;">{{ soldes.vers_section|number_format(2, ',', ' ') }} €</td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            {% else %}
                <p style="padding:24px;opacity:.3;text-align:center;font-style:italic;">
                    Aucune opération financière enregistrée pour cet adhérent.
                </p>
            {% endif %}
        </div>

    </main>
</div>
<style>
    body.theme-dark .btn-primary { background:#4299e1;color:#fff; }
    body.theme-sky  .btn-primary { background:#2b6cb0;color:#fff; }
</style>
{% endblock %}
