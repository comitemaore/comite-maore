{# templates/organigramme/form.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}{{ titre }} — Comité Maoré{% endblock %}
{% block body_theme %}dark{% endblock %}

{% block navbar %}
<nav class="navbar">
    <a class="navbar-brand" href="{{ path('app_dashboard') }}"> Comité Maoré</a>
    <div class="navbar-right">
        <span style="font-size:13px;opacity:.8;">{{ app.user.userIdentifier }}</span>
        <a href="{{ back_url }}" class="btn btn-secondary btn-sm">← Retour</a>
        <a href="{{ path('app_logout') }}" class="btn btn-danger btn-sm">Déconnexion</a>
    </div>
</nav>
{% endblock %}

{% block body %}
<div class="layout">
    <aside class="sidebar">
        <a href="{{ path('app_dashboard') }}">📊 Tableau de bord</a>
        <a href="{{ path('app_adherent_list') }}">👥 Adhérents</a>
        <a href="{{ path('app_organigramme') }}" class="active">🏛 Organigramme</a>
        <a href="{{ path('app_log_list') }}">📋 Logs</a>
        <hr style="margin:16px 20px;border:none;border-top:1px solid rgba(255,255,255,.15);">
        <a href="{{ path('app_logout') }}">🚪 Déconnexion</a>
    </aside>

    <main class="main-content">
        <h1 style="font-size:21px;font-weight:700;margin-bottom:4px;">✏️ {{ titre }}</h1>
        <p style="font-size:13px;opacity:.5;margin-bottom:20px;">
            Sélectionnez un adhérent pour chaque fonction. Tapez un nom pour filtrer la liste.
            Seul <code>admin</code> peut enregistrer les modifications.
        </p>

        {% if error %}<div class="alert alert-danger">{{ error }}</div>{% endif %}

        <form method="post" id="orgForm">

            {# Nom du bureau (uniquement pour mode bureau) #}
            {% if mode == 'bureau' %}
            <div class="card" style="margin-bottom:16px;">
                <div class="form-group" style="max-width:400px;margin:0;">
                    <label>Nom du bureau</label>
                    <input type="text" name="nom_bureau" class="form-control"
                           value="{{ entite.nom_bureau ?? 'Bureau Exécutif National' }}">
                </div>
            </div>
            {% endif %}

            {# Nom complet (uniquement pour mode fédération) #}
            {% if mode == 'federation' %}
            <div class="card" style="margin-bottom:16px;">
                <div class="form-group" style="max-width:400px;margin:0;">
                    <label>Nom complet de la fédération</label>
                    <input type="text" name="nom_complet" class="form-control"
                           value="{{ entite.nom_complet ?? '' }}"
                           placeholder="ex: Fédération Maoré Île-de-France">
                </div>
            </div>
            {% endif %}

            {# Barre de recherche adhérent globale #}
            <div style="margin-bottom:16px;padding:12px 16px;border-radius:8px;
                        background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);">
                <label style="font-size:12px;opacity:.6;display:block;margin-bottom:6px;">
                    Recherche rapide d'adhérent (filtre toutes les listes ci-dessous)
                </label>
                <input type="text" id="globalSearch" class="form-control"
                       placeholder="Tapez un nom ou prénom..."
                       style="max-width:400px;"
                       oninput="filterAll(this.value)">
            </div>

            {# Grille des fonctions #}
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">

                {% set groupes = {
                    'Direction' : ['president', 'vice_president'],
                    'Secrétariat' : ['secretaire', 'secretaire_adjoint'],
                    'Trésorerie' : ['tresorier', 'tresorier_adjoint'],
                    'Administrateurs' : ['administrateur1', 'administrateur2', 'administrateur3']
                } %}

                {% for groupe, cols in groupes %}
                <div class="card" style="padding:16px;">
                    <div style="font-size:12px;font-weight:600;opacity:.5;text-transform:uppercase;
                                letter-spacing:.06em;margin-bottom:12px;">{{ groupe }}</div>
                    {% for col in cols %}
                    <div class="form-group" style="margin-bottom:12px;">
                        <label style="font-size:12px;">{{ fonctions[col] }}</label>
                        <select name="{{ col }}" id="sel_{{ col }}" class="form-control fn-select"
                                data-current="{{ entite[col] ?? '' }}"
                                style="font-size:13px;">
                            <option value="">— Non attribué —</option>
                            {% for adht in adherents %}
                                <option value="{{ adht.id_adht }}"
                                    {{ (entite[col] ?? '') == adht.id_adht ? 'selected' : '' }}>
                                    {{ adht.nom_adht }} {{ adht.prenom_adht }}
                                    {% if adht.profession_adht %} · {{ adht.profession_adht }}{% endif %}
                                    {% if mode == 'bureau' and adht.section is defined %} ({{ adht.section }}){% endif %}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    {% endfor %}
                </div>
                {% endfor %}

            </div>

            {# Aperçu en temps réel #}
            <div class="card" style="margin-top:16px;" id="preview">
                <div class="card-title" style="font-size:14px;">Aperçu de l'organigramme</div>
                <div id="previewGrid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;font-size:13px;">
                    {% for col, label in fonctions %}
                    <div id="prev_{{ col }}" style="padding:8px;border-radius:5px;background:rgba(255,255,255,.04);">
                        <div style="font-size:10px;opacity:.5;text-transform:uppercase;margin-bottom:3px;">{{ label }}</div>
                        <div id="prev_{{ col }}_txt" style="font-weight:500;">
                            {{ entite[col] is defined and entite[col] ? '...' : '—' }}
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div style="display:flex;gap:10px;margin-top:20px;">
                <button type="submit" class="btn btn-success">💾 Enregistrer l'organigramme</button>
                <a href="{{ back_url }}" class="btn btn-secondary">Annuler</a>
            </div>

        </form>
    </main>
</div>

<style>
    .btn-primary{background:#4299e1;color:#fff;}
    option:checked{background:#1e3a5f;}
</style>

<script>
// Noms des adhérents pour l'aperçu
const NOMS = {};
document.querySelectorAll('.fn-select').forEach(sel => {
    sel.querySelectorAll('option').forEach(opt => {
        if (opt.value) NOMS[opt.value] = opt.textContent.trim().split(' · ')[0];
    });
    sel.addEventListener('change', updatePreview);
});

function updatePreview() {
    document.querySelectorAll('.fn-select').forEach(sel => {
        const col  = sel.name;
        const val  = sel.value;
        const txt  = document.getElementById('prev_' + col + '_txt');
        if (txt) txt.textContent = val ? (NOMS[val] || '#' + val) : '—';
    });
}
updatePreview();

// Filtre global sur toutes les listes
function filterAll(q) {
    q = q.toLowerCase();
    document.querySelectorAll('.fn-select').forEach(sel => {
        sel.querySelectorAll('option').forEach(opt => {
            if (!opt.value) return;
            opt.style.display = opt.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });
}
</script>
{% endblock %}
