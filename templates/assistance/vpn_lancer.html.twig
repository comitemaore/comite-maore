{# templates/assistance/vpn_lancer.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}Session VPN — Comité Maoré{% endblock %}
{% block body_theme %}dark{% endblock %}

{% block navbar %}
<nav class="navbar">
    <a class="navbar-brand" href="{{ path('app_dashboard') }}">🌿 Comité Maoré</a>
    <div class="navbar-right">
        <a href="{{ path('app_assistance') }}" class="btn btn-secondary btn-sm">← Assistance</a>
        <a href="{{ path('app_logout') }}" class="btn btn-danger btn-sm">Déconnexion</a>
    </div>
</nav>
{% endblock %}

{% block body %}
<div class="layout">
    <aside class="sidebar">
        <a href="{{ path('app_dashboard') }}">📊 Tableau de bord</a>
        <a href="{{ path('app_assistance') }}" class="active">🆘 Assistance</a>
        <hr style="margin:16px 20px;border:none;border-top:1px solid rgba(255,255,255,.15);">
        <a href="{{ path('app_logout') }}">🚪 Déconnexion</a>
    </aside>

    <main class="main-content" style="max-width:640px;">
        <h1 style="font-size:22px;font-weight:700;margin-bottom:20px;">🔌 Session OpenVPN</h1>

        <div class="alert alert-success">
            ✅ Fichier de configuration <strong>{{ filename }}</strong> importé avec succès.
        </div>

        <div class="card" style="border:1px solid rgba(66,153,225,.3);">
            <div class="card-title" style="color:#90cdf4;">Instructions pour lancer la session</div>

            <p style="font-size:13px;opacity:.8;margin-bottom:16px;">
                Le fichier a été stocké de façon sécurisée. Pour lancer la connexion OpenVPN,
                exécutez la commande suivante sur le <strong>serveur</strong> :
            </p>

            <pre style="background:#0f1117;padding:14px 16px;border-radius:6px;font-size:13px;
                        font-family:monospace;color:#9ae6b4;border:1px solid rgba(104,211,145,.2);">sudo openvpn --config var/vpn_configs/{{ filename }} --daemon</pre>

            <p style="font-size:12px;opacity:.5;margin-top:8px;">
                Ou via le service systemd si configuré :<br>
                <code>sudo systemctl start openvpn@{{ filename|replace({'.ovpn': '', '.conf': ''}) }}</code>
            </p>

            <div style="margin-top:16px;padding:12px;border-radius:6px;background:rgba(229,62,62,.08);
                        border:1px solid rgba(229,62,62,.2);font-size:12px;color:#fc8181;">
                ⚠ <strong>Sécurité :</strong> pensez à arrêter la session une fois l'intervention terminée :<br>
                <code>sudo systemctl stop openvpn@{{ filename|replace({'.ovpn': '', '.conf': ''}) }}</code>
                <br>ou supprimez le fichier de configuration : <code>rm var/vpn_configs/{{ filename }}</code>
            </div>
        </div>

        <div class="card" style="margin-top:12px;">
            <div class="card-title">📋 Session tracée</div>
            <table class="table">
                <tbody>
                    <tr><td style="opacity:.6;width:40%;">Fichier</td><td><code>{{ filename }}</code></td></tr>
                    <tr><td style="opacity:.6;">Demandeur</td><td>{{ login }}</td></tr>
                    <tr><td style="opacity:.6;">Heure</td><td>{{ "now"|date("d/m/Y H:i:s") }}</td></tr>
                </tbody>
            </table>
        </div>

        <div style="margin-top:16px;display:flex;gap:10px;">
            <a href="{{ path('app_assistance') }}" class="btn btn-secondary">← Retour assistance</a>
            <a href="{{ path('app_dashboard') }}" class="btn btn-secondary">Tableau de bord</a>
        </div>
    </main>
</div>
<style>
    code{font-family:'Courier New',monospace;font-size:11px;background:rgba(255,255,255,.08);padding:1px 5px;border-radius:3px;}
</style>
{% endblock %}
