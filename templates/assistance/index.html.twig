{# templates/assistance/index.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}Assistance technique — Comité Maoré{% endblock %}
{% block body_theme %}dark{% endblock %}

{% block navbar %}
<nav class="navbar">
    <a class="navbar-brand" href="{{ path('app_dashboard') }}"> Comité Maoré</a>
    <div class="navbar-right">
        <span style="font-size:13px;opacity:.8;">{{ app.user.userIdentifier }}</span>
        <span class="badge badge-admin">ADMIN</span>
        <a href="{{ path('app_logout') }}" class="btn btn-danger btn-sm">Déconnexion</a>
    </div>
</nav>
{% endblock %}

{% block body %}
<div class="layout">
    <aside class="sidebar">
        <a href="{{ path('app_dashboard') }}">📊 Tableau de bord</a>
        <a href="{{ path('app_adherent_list') }}">👥 Adhérents</a>
        <a href="{{ path('app_log_list') }}">📋 Logs</a>
        <a href="{{ path('app_assistance') }}" class="active">🆘 Assistance</a>
        <a href="{{ path('app_organigramme') }}">🏛 Organigramme</a>
        <hr style="margin:16px 20px;border:none;border-top:1px solid rgba(255,255,255,.15);">
        <a href="{{ path('app_logout') }}">🚪 Déconnexion</a>
    </aside>

    <main class="main-content">
        <h1 style="font-size:22px;font-weight:700;margin-bottom:4px;">🆘 Assistance technique</h1>
        <p style="font-size:13px;opacity:.5;margin-bottom:24px;">Réservé aux administrateurs.</p>

        {% for msg in app.flashes('danger') %}<div class="alert alert-danger">{{ msg }}</div>{% endfor %}
        {% for msg in app.flashes('success') %}<div class="alert alert-success">{{ msg }}</div>{% endfor %}

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">

            {# ======================================================= #}
            {# BLOC 2 — TICKET DE DÉPANNAGE                            #}
            {# ======================================================= #}
            <div class="card" style="border:1px solid rgba(229,62,62,.35);">

                <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
                    <span style="font-size:26px;">🎫</span>
                    <div>
                        <div style="font-weight:700;font-size:16px;color:#fc8181;">
                            Ticket de dépannage
                        </div>
                        <div style="font-size:12px;opacity:.5;">
                            Mail à l'administrateur technique + texte d'issue GitHub
                        </div>
                    </div>
                </div>

                <form method="post" action="{{ path('app_assistance_ticket') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('assistance_ticket') }}">

                    {# Type #}
                    <div style="display:flex;gap:6px;margin-bottom:14px;">
                        {% for val, label in {'bug':'🐛 Bug','support':'❓ Support','feature':'✨ Amélioration'} %}
                        <label id="lbl_{{ val }}" style="flex:1;display:flex;align-items:center;gap:5px;
                               padding:7px 8px;border-radius:5px;cursor:pointer;font-size:12px;
                               border:1px solid rgba(255,255,255,.15);">
                            <input type="radio" name="type" value="{{ val }}"
                                   {{ loop.first ? 'checked' : '' }}
                                   onchange="selectType('{{ val }}')">
                            {{ label }}
                        </label>
                        {% endfor %}
                    </div>

                    <div class="form-group">
                        <label style="font-size:12px;">Urgence</label>
                        <select name="urgence" class="form-control">
                            <option value="normal">🟡 Normal</option>
                            <option value="important">🟠 Important</option>
                            <option value="bloquant">🔴 Bloquant</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label style="font-size:12px;">Titre *</label>
                        <input type="text" name="titre" class="form-control" required
                               placeholder="ex: Impossible de se connecter...">
                    </div>

                    <div class="form-group">
                        <label style="font-size:12px;">Module concerné</label>
                        <select name="module" class="form-control">
                            <option value="">-- Choisir --</option>
                            {% for m in ['Connexion','Adhérents','Organigramme','Finances',
                                'Documents','Approbation','Import CSV','Admin BDD','Autre'] %}
                                <option>{{ m }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="form-group">
                        <label style="font-size:12px;">Description *</label>
                        <textarea name="description" class="form-control" rows="3" required
                                  placeholder="Décrivez le problème..."></textarea>
                    </div>

                    <div id="bug_fields">
                        <div class="form-group">
                            <label style="font-size:12px;">Étapes pour reproduire</label>
                            <textarea name="reproduction" class="form-control" rows="2"
                                      placeholder="1. Aller sur /adherent&#10;2. Cliquer...&#10;3. Erreur"></textarea>
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                            <div class="form-group">
                                <label style="font-size:12px;">Comportement attendu</label>
                                <textarea name="attendu" class="form-control" rows="2"></textarea>
                            </div>
                            <div class="form-group">
                                <label style="font-size:12px;">Comportement réel</label>
                                <textarea name="reel" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                        <div class="form-group">
                            <label style="font-size:12px;">Message d'erreur</label>
                            <textarea name="erreur" class="form-control" rows="2"
                                      style="font-family:monospace;font-size:11px;"
                                      placeholder="Copiez le message d'erreur exact..."></textarea>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-danger"
                            style="width:100%;padding:12px;font-size:14px;font-weight:600;"
                            onclick="return confirm('Envoyer ce ticket au technicien ?');">
                        🎫 Envoyer le ticket de dépannage
                    </button>
                </form>

                {# Liens GitHub directs #}
                <div style="margin-top:14px;padding-top:12px;border-top:1px solid rgba(255,255,255,.08);">
                    <div style="font-size:11px;opacity:.5;margin-bottom:6px;">Ou créer une issue GitHub :</div>
                    <div style="display:flex;gap:6px;flex-wrap:wrap;">
                        <a href="https://github.com/{{ github_repo }}/issues/new?template=bug_report.md"
                           target="_blank" class="btn btn-secondary btn-sm">🐛 Bug</a>
                        <a href="https://github.com/{{ github_repo }}/issues/new?template=question_support.md"
                           target="_blank" class="btn btn-secondary btn-sm">❓ Support</a>
                        <a href="https://github.com/{{ github_repo }}/issues/new?template=feature_request.md"
                           target="_blank" class="btn btn-secondary btn-sm">✨ Feature</a>
                    </div>
                </div>
            </div>

            {# ======================================================= #}
            {# BLOC 1 — PRISE EN MAIN À DISTANCE (OpenVPN)             #}
            {# ======================================================= #}
            <div class="card" style="border:1px solid rgba(66,153,225,.4);">

                <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
                    <span style="font-size:26px;">🖥</span>
                    <div>
                        <div style="font-weight:700;font-size:16px;color:#90cdf4;">
                            Prise en main à distance
                        </div>
                        <div style="font-size:12px;opacity:.5;">Via OpenVPN — fichier .ovpn fourni par le technicien</div>
                    </div>
                </div>

                {# Indicateur statut VPN #}
                <div id="vpn-statut-bar" style="display:flex;align-items:center;gap:8px;padding:8px 12px;
                     border-radius:6px;margin-bottom:16px;font-size:13px;
                     background:{{ vpn_statut.actif ? 'rgba(56,161,105,.15)' : 'rgba(255,255,255,.05)' }};
                     border:1px solid {{ vpn_statut.actif ? 'rgba(56,161,105,.4)' : 'rgba(255,255,255,.1)' }};">
                    <span id="vpn-dot" style="width:10px;height:10px;border-radius:50%;flex-shrink:0;
                          background:{{ vpn_statut.actif ? '#38a169' : '#718096' }};
                          {{ vpn_statut.actif ? 'box-shadow:0 0 0 3px rgba(56,161,105,.25);animation:pulse 2s infinite;' : '' }}">
                    </span>
                    <span id="vpn-label" style="color:{{ vpn_statut.actif ? '#9ae6b4' : '#a0aec0' }};">
                        {% if vpn_statut.actif %}
                            Connexion VPN active (PID : {{ vpn_statut.pid }})
                        {% else %}
                            Aucune connexion VPN active
                        {% endif %}
                    </span>
                </div>

                {% if not scripts_ok %}
                <div style="padding:10px 14px;border-radius:6px;background:rgba(229,62,62,.1);
                            border:1px solid rgba(229,62,62,.3);font-size:12px;color:#fc8181;margin-bottom:14px;">
                    ⚠ Scripts VPN non installés sur le serveur.
                    Consultez <code>scripts/INSTALL.md</code> pour l'installation.
                </div>
                {% endif %}

                {# ---- ÉTAPE 1 : Import du fichier .ovpn ---- #}
                <div style="margin-bottom:20px;">
                    <div style="font-size:12px;font-weight:600;opacity:.6;text-transform:uppercase;
                                letter-spacing:.05em;margin-bottom:10px;">
                        Étape 1 — Importer le profil OpenVPN
                    </div>

                    {% if vpn_files|length > 0 %}
                    <div style="padding:8px 12px;border-radius:6px;background:rgba(104,211,145,.1);
                                border:1px solid rgba(104,211,145,.25);font-size:12px;
                                color:#9ae6b4;margin-bottom:10px;">
                        ✓ Profil importé :
                        {% for f in vpn_files %}
                            <strong>{{ f.nom }}</strong>
                            <span style="opacity:.6;">({{ f.taille }} — {{ f.date }})</span>
                        {% endfor %}
                    </div>
                    {% endif %}

                    <form method="post" enctype="multipart/form-data"
                          action="{{ path('app_assistance_vpn_upload') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('assistance_vpn') }}">
                        <div style="display:flex;gap:8px;align-items:flex-end;">
                            <div style="flex:1;">
                                <input type="file" name="vpn_config" class="form-control"
                                       accept=".ovpn" required
                                       style="font-size:12px;">
                                <small style="font-size:11px;opacity:.4;display:block;margin-top:3px;">
                                    Fichier .ovpn fourni par votre technicien
                                </small>
                            </div>
                            <button type="submit" class="btn btn-sm"
                                    style="background:#4299e1;color:#fff;white-space:nowrap;">
                                📥 Importer
                            </button>
                        </div>
                    </form>
                </div>

                {# ---- ÉTAPE 2 : Lancer la connexion ---- #}
                <div style="margin-bottom:20px;">
                    <div style="font-size:12px;font-weight:600;opacity:.6;text-transform:uppercase;
                                letter-spacing:.05em;margin-bottom:10px;">
                        Étape 2 — Lancer / Arrêter la connexion
                    </div>

                    {% if vpn_files|length > 0 %}
                        {% set vpn_file = vpn_files[0] %}
                        <div style="display:flex;gap:10px;">

                            {# Bouton LANCER #}
                            <button id="btn-lancer" type="button"
                                    onclick="lancerVPN('{{ vpn_file.nom }}')"
                                    class="btn" style="flex:1;padding:12px;font-size:14px;font-weight:600;
                                           background:#276749;color:#9ae6b4;border:1px solid #38a169;"
                                    {{ vpn_statut.actif ? 'disabled' : '' }}>
                                🔌 Lancer la connexion VPN
                            </button>

                            {# Bouton ARRÊTER (rouge, toujours visible) #}
                            <button id="btn-arreter" type="button"
                                    onclick="arreterVPN('{{ vpn_file.nom }}')"
                                    class="btn btn-danger" style="flex:1;padding:12px;font-size:14px;font-weight:600;"
                                    {{ not vpn_statut.actif ? 'disabled' : '' }}>
                                ⏹ Couper + Supprimer le profil
                            </button>

                        </div>

                        <input type="hidden" id="vpn-csrf-lancer"  value="{{ csrf_token('vpn_lancer') }}">
                        <input type="hidden" id="vpn-csrf-arreter" value="{{ csrf_token('vpn_arreter') }}">

                        <div id="vpn-msg" style="margin-top:10px;font-size:13px;display:none;padding:8px 12px;border-radius:6px;"></div>

                    {% else %}
                        <div style="font-size:13px;opacity:.4;font-style:italic;">
                            Importez d'abord un fichier .ovpn à l'étape 1.
                        </div>
                    {% endif %}
                </div>

                {# Avertissement sécurité #}
                <div style="padding:8px 12px;border-radius:6px;background:rgba(229,62,62,.08);
                            border:1px solid rgba(229,62,62,.2);font-size:11px;color:#fc8181;">
                    ⚠ Le fichier .ovpn est <strong>automatiquement supprimé</strong> à l'arrêt de la connexion.
                    N'utilisez que des profils fournis par votre technicien officiel. Session tracée dans les logs.
                </div>
            </div>

            {# Infos système pour le technicien #}
                <div class="card" style="margin-top:12px;padding:14px 16px;">
                    <div style="font-size:12px;font-weight:600;margin-bottom:8px;opacity:.7;">
                        Informations système (à communiquer au technicien)
                    </div>
                    <table style="width:100%;font-size:12px;">
                        <tr>
                            <td style="opacity:.5;padding:3px 0;width:40%;">Serveur PHP</td>
                            <td>{{ constant('PHP_VERSION') }}</td>
                        </tr>
                        <tr>
                            <td style="opacity:.5;padding:3px 0;">Environnement</td>
                            <td>{{ app.environment }}</td>
                        </tr>
                        <tr>
                            <td style="opacity:.5;padding:3px 0;">Utilisateur connecté</td>
                            <td>{{ app.user.userIdentifier }}</td>
                        </tr>
                        <tr>
                            <td style="opacity:.5;padding:3px 0;">Date/heure serveur</td>
                            <td>{{ "now"|date("d/m/Y H:i:s") }}</td>
                        </tr>
                    </table>
                </div>

        </div>{# /grid #}
    </main>
</div>

<style>
@keyframes pulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(56,161,105,.4); }
    50%      { box-shadow: 0 0 0 6px rgba(56,161,105,0); }
}
code { font-family:'Courier New',monospace;font-size:11px;background:rgba(255,255,255,.1);padding:1px 5px;border-radius:3px; }
</style>

<script>
// --- Type de ticket ---
function selectType(type) {
    document.getElementById('bug_fields').style.display = type === 'feature' ? 'none' : 'block';
    ['bug','support','feature'].forEach(t => {
        const el = document.getElementById('lbl_' + t);
        el.style.background   = t === type ? 'rgba(255,255,255,.08)' : 'transparent';
        el.style.borderColor  = t === type ? 'rgba(255,255,255,.35)' : 'rgba(255,255,255,.15)';
    });
}
selectType('bug');

// --- Lancer VPN ---
async function lancerVPN(filename) {
    if (!confirm('Lancer la connexion VPN avec le profil « ' + filename + ' » ?\n\nLe fichier sera modifié pour fonctionner en mode non-interactif, puis OpenVPN sera lancé en arrière-plan.')) return;

    const btn = document.getElementById('btn-lancer');
    btn.disabled = true;
    btn.textContent = '⏳ Connexion en cours...';
    afficherMsg('', '');

    const fd = new FormData();
    fd.append('filename', filename);
    fd.append('_token', document.getElementById('vpn-csrf-lancer').value);

    try {
        const r = await fetch('{{ path("app_assistance_vpn_lancer") }}', { method:'POST', body:fd });
        const d = await r.json();
        if (d.ok) {
            afficherMsg(d.message, 'ok');
            setStatut(true);
            btn.disabled = true;
            document.getElementById('btn-arreter').disabled = false;
        } else {
            afficherMsg(d.message, 'erreur');
            btn.disabled = false;
            btn.textContent = '🔌 Lancer la connexion VPN';
        }
    } catch(e) {
        afficherMsg('Erreur réseau : ' + e.message, 'erreur');
        btn.disabled = false;
        btn.textContent = '🔌 Lancer la connexion VPN';
    }
}

// --- Arrêter VPN ---
async function arreterVPN(filename) {
    if (!confirm('Couper la connexion VPN ?\n\nLe fichier « ' + filename + ' » sera définitivement supprimé.')) return;

    const btn = document.getElementById('btn-arreter');
    btn.disabled = true;
    btn.textContent = '⏳ Arrêt en cours...';

    const fd = new FormData();
    fd.append('filename', filename);
    fd.append('_token', document.getElementById('vpn-csrf-arreter').value);

    try {
        const r = await fetch('{{ path("app_assistance_vpn_arreter") }}', { method:'POST', body:fd });
        const d = await r.json();
        afficherMsg(d.message, d.ok ? 'ok' : 'erreur');
        setStatut(false);
        btn.disabled = true;
        // Recharger la page pour effacer le fichier de la liste
        setTimeout(() => location.reload(), 1500);
    } catch(e) {
        afficherMsg('Erreur réseau : ' + e.message, 'erreur');
        btn.disabled = false;
        btn.textContent = '⏹ Couper + Supprimer le profil';
    }
}

// --- Mise à jour de l'indicateur statut ---
function setStatut(actif) {
    const bar   = document.getElementById('vpn-statut-bar');
    const dot   = document.getElementById('vpn-dot');
    const label = document.getElementById('vpn-label');
    if (actif) {
        bar.style.background   = 'rgba(56,161,105,.15)';
        bar.style.borderColor  = 'rgba(56,161,105,.4)';
        dot.style.background   = '#38a169';
        dot.style.animation    = 'pulse 2s infinite';
        dot.style.boxShadow    = '0 0 0 3px rgba(56,161,105,.25)';
        label.style.color      = '#9ae6b4';
        label.textContent      = 'Connexion VPN active';
    } else {
        bar.style.background   = 'rgba(255,255,255,.05)';
        bar.style.borderColor  = 'rgba(255,255,255,.1)';
        dot.style.background   = '#718096';
        dot.style.animation    = '';
        dot.style.boxShadow    = '';
        label.style.color      = '#a0aec0';
        label.textContent      = 'Aucune connexion VPN active';
    }
}

function afficherMsg(msg, type) {
    const el = document.getElementById('vpn-msg');
    if (!msg) { el.style.display = 'none'; return; }
    el.style.display    = 'block';
    el.style.background = type === 'ok' ? 'rgba(56,161,105,.15)' : 'rgba(229,62,62,.15)';
    el.style.border     = '1px solid ' + (type === 'ok' ? 'rgba(56,161,105,.4)' : 'rgba(229,62,62,.4)');
    el.style.color      = type === 'ok' ? '#9ae6b4' : '#fc8181';
    el.textContent      = msg;
}

// Polling statut toutes les 10s
setInterval(async () => {
    try {
        const r = await fetch('{{ path("app_assistance_vpn_statut") }}');
        const d = await r.json();
        setStatut(d.actif);
    } catch {}
}, 10000);
</script>
{% endblock %}
